---
import { getI18N } from '@/i18n'
const { currentLocale } = Astro
const i18n = getI18N({ currentLocale })
---
<section class="space-y-6">
	<h2 class="font-display flex items-center gap-x-2 text-3xl font-semibold">
		{i18n.styleguide.colors.title}
	</h2>
	<div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
		<!-- Primary Gradient -->
		<div class="group rounded-2xl border border-neutral-800 bg-neutral-900/60 p-5 backdrop-blur-md transition-all hover:bg-neutral-800/80 hover:border-neutral-700">
			<div class="mb-5 h-28 w-full rounded-xl bg-linear-to-r from-[#b16cea] via-[#ff5e69] to-[#ffa84b] shadow-inner"></div>
			<h3 class="font-heading text-xl font-bold text-white">Gradiente Principal</h3>
			<p class="font-accent mt-2 text-sm text-neutral-400">
				{i18n.styleguide.colors.description}
			</p>
			<div class="mt-5 flex flex-col gap-3 font-mono text-xs text-neutral-400">
				<div class="flex items-center justify-between"><span class="flex items-center gap-3"><span class="h-4 w-4 rounded-full bg-[#b16cea] shadow-sm"></span>#b16cea</span></div>
				<div class="flex items-center justify-between"><span class="flex items-center gap-3"><span class="h-4 w-4 rounded-full bg-[#ff5e69] shadow-sm"></span>#ff5e69</span></div>
				<div class="flex items-center justify-between"><span class="flex items-center gap-3"><span class="h-4 w-4 rounded-full bg-[#ffa84b] shadow-sm"></span>#ffa84b</span></div>
			</div>
		</div>

		<!-- Neutral Colors -->
		<div class="group rounded-2xl border border-neutral-800 bg-neutral-900/60 p-5 backdrop-blur-md transition-all hover:bg-neutral-800/80 hover:border-neutral-700">
			<div class="mb-5 flex h-28 w-full overflow-hidden rounded-xl border border-neutral-800 shadow-inner">
				<div class="h-full w-1/3 bg-neutral-950"></div>
				<div class="h-full w-1/3 bg-neutral-900"></div>
				<div class="h-full w-1/3 bg-neutral-800"></div>
			</div>
			<h3 class="font-heading text-xl font-bold text-white">Neutros Oscuros</h3>
			<p class="font-accent mt-2 text-sm text-neutral-400">
				Fondos principales y contenedores en el modo oscuro (por defecto).
			</p>
			<div class="mt-5 flex flex-col gap-3 font-mono text-xs text-neutral-400">
				<div class="flex items-center justify-between"><span class="flex items-center gap-3"><span class="h-4 w-4 rounded-full bg-neutral-950 border border-neutral-800"></span>bg-neutral-950</span></div>
				<div class="flex items-center justify-between"><span class="flex items-center gap-3"><span class="h-4 w-4 rounded-full bg-neutral-900 border border-neutral-800"></span>bg-neutral-900</span></div>
				<div class="flex items-center justify-between"><span class="flex items-center gap-3"><span class="h-4 w-4 rounded-full bg-neutral-800 border border-neutral-700"></span>bg-neutral-800</span></div>
			</div>
		</div>

		<!-- Accent Selection -->
		<div class="group rounded-2xl border border-neutral-800 bg-neutral-900/60 p-5 backdrop-blur-md transition-all hover:bg-neutral-800/80 hover:border-neutral-700 sm:col-span-2 lg:col-span-1">
			<div class="mb-5 flex h-28 w-full items-center justify-center rounded-xl bg-[#ffe1e3] shadow-inner">
				<span class="font-accent text-xl font-bold text-[#ff5e69]">Texto Resaltado</span>
			</div>
			<h3 class="font-heading text-xl font-bold text-white">Color de Selección</h3>
			<p class="font-accent mt-2 text-sm text-neutral-400">
				Definido en el seudo-elemento ::selection global.
			</p>
			<div class="mt-5 flex flex-col gap-3 font-mono text-xs text-neutral-400">
				<div class="flex items-center justify-between"><span class="flex items-center gap-3"><span class="h-4 w-4 rounded-full bg-[#ffe1e3]"></span>Fondo: #ffe1e3</span></div>
				<div class="flex items-center justify-between"><span class="flex items-center gap-3"><span class="h-4 w-4 rounded-full bg-[#ff5e69]"></span>Texto: #ff5e69</span></div>
			</div>
		</div>
	</div>
</section>
