---
import Arrow from '@/components/icons/Arrow.astro'
import DropdownArrow from '@/components/icons/DropdownArrow.astro'
import Bug from '@/components/icons/bug.astro'
import External from '@/components/icons/external.astro'
import Github from '@/components/icons/github.astro'
import Home from '@/components/icons/home.astro'
import Reload from '@/components/icons/reload.astro'
import Type from '@/components/icons/type.astro'
import { getI18N } from '@/i18n'
const { currentLocale } = Astro
const i18n = getI18N({ currentLocale })
---
<section class="space-y-6 pt-10">
	<h2 class="font-display flex items-center gap-x-2 text-3xl font-semibold">
		{i18n.styleguide.icons.title}
	</h2>
	
    <div class="group rounded-2xl border border-neutral-800 bg-neutral-900/60 p-6 backdrop-blur-md transition-all hover:border-neutral-700 hover:bg-neutral-800/80">
        <h3 class="font-heading mb-6 text-xl font-bold text-white">{i18n.styleguide.icons.subtitle}</h3>
        
        <div class="grid grid-cols-2 gap-4 sm:grid-cols-4 md:grid-cols-6 lg:grid-cols-8">
            <div class="flex flex-col items-center justify-center gap-2 rounded-xl border border-neutral-200 bg-white p-4 transition-colors hover:bg-neutral-100 shadow-sm">
                <Arrow class="h-6 w-6 text-neutral-800" />
                <span class="font-accent text-xs font-medium text-neutral-600">Arrow</span>
            </div>
            
            <div class="flex flex-col items-center justify-center gap-2 rounded-xl border border-neutral-200 bg-white p-4 transition-colors hover:bg-neutral-100 shadow-sm">
                <DropdownArrow class="h-6 w-6 text-neutral-800" />
                <span class="font-accent text-xs font-medium text-neutral-600">Dropdown</span>
            </div>
            
            <div class="flex flex-col items-center justify-center gap-2 rounded-xl border border-neutral-200 bg-white p-4 transition-colors hover:bg-neutral-100 shadow-sm">
                <Bug class="h-6 w-6 text-neutral-800" />
                <span class="font-accent text-xs font-medium text-neutral-600">Bug</span>
            </div>
            
            <div class="flex flex-col items-center justify-center gap-2 rounded-xl border border-neutral-200 bg-white p-4 transition-colors hover:bg-neutral-100 shadow-sm">
                <External class="h-6 w-6 text-neutral-800" />
                <span class="font-accent text-xs font-medium text-neutral-600">External</span>
            </div>
            
            <div class="flex flex-col items-center justify-center gap-2 rounded-xl border border-neutral-200 bg-white p-4 transition-colors hover:bg-neutral-100 shadow-sm">
                <Github class="h-6 w-6 text-neutral-800" />
                <span class="font-accent text-xs font-medium text-neutral-600">Github</span>
            </div>
            
            <div class="flex flex-col items-center justify-center gap-2 rounded-xl border border-neutral-200 bg-white p-4 transition-colors hover:bg-neutral-100 shadow-sm">
                <Home class="h-6 w-6 text-neutral-800" />
                <span class="font-accent text-xs font-medium text-neutral-600">Home</span>
            </div>

            <div class="flex flex-col items-center justify-center gap-2 rounded-xl border border-neutral-200 bg-white p-4 transition-colors hover:bg-neutral-100 shadow-sm">
                <Reload class="h-6 w-6 text-neutral-800" />
                <span class="font-accent text-xs font-medium text-neutral-600">Reload</span>
            </div>

            <div class="flex flex-col items-center justify-center gap-2 rounded-xl border border-neutral-200 bg-white p-4 transition-colors hover:bg-neutral-100 shadow-sm">
                <Type class="h-6 w-6 text-neutral-800" />
                <span class="font-accent text-xs font-medium text-neutral-600">Type</span>
            </div>
        </div>
        
        <p class="font-accent mt-6 text-sm text-neutral-400">
            {i18n.styleguide.icons.description}
        </p>
    </div>
</section>
