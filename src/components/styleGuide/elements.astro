---
import Pill from '@/components/ui/pill.astro'
import { getI18N } from '@/i18n'
const { currentLocale } = Astro
const i18n = getI18N({ currentLocale })
---
<section class="space-y-6 pt-10">
	<h2 class="font-display flex items-center gap-x-2 text-3xl font-semibold">
		{i18n.styleguide.elements.title}
	</h2>
	<div class="grid grid-cols-1 gap-6 md:grid-cols-2">
		<!-- Buttons -->
		<div class="group rounded-2xl border border-neutral-800 bg-neutral-900/60 p-6 backdrop-blur-md transition-all hover:border-neutral-700 hover:bg-neutral-800/80">
			<h3 class="font-heading mb-6 text-xl font-bold text-white">{i18n.styleguide.elements.buttons.title}</h3>
			<div class="flex flex-wrap items-center gap-6">
				<button class="font-heading relative inline-flex h-10 items-center justify-center bg-neutral-950 px-5 text-sm text-white shadow-sm transition-colors hover:bg-neutral-800">
					{i18n.styleguide.elements.buttons.primary}
				</button>
				<button class="flex h-10 items-center gap-2 rounded-full bg-neutral-800 px-5 text-sm font-medium text-white shadow-sm transition-colors hover:bg-neutral-700">
					<span>{i18n.styleguide.elements.buttons.cv}</span>
                    <svg class="h-4 w-4" viewBox="0 0 384 512" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
                        <path d="M169.4 470.6c12.5 12.5 32.8 12.5 45.3 0l160-160c12.5-12.5 12.5-32.8 0-45.3s-32.8-12.5-45.3 0L224 370.8 224 64c0-17.7-14.3-32-32-32s-32 14.3-32 32l0 306.7L54.6 265.4c-12.5-12.5-32.8-12.5-45.3 0s-12.5 32.8 0 45.3l160 160z"></path>
                    </svg>
				</button>
			</div>
            <p class="font-accent mt-6 text-sm text-neutral-400">
				{i18n.styleguide.elements.buttons.description}
			</p>
		</div>
		
		<!-- Pills -->
		<div class="group rounded-2xl border border-neutral-800 bg-neutral-900/60 p-6 backdrop-blur-md transition-all hover:border-neutral-700 hover:bg-neutral-800/80">
			<h3 class="font-heading mb-6 text-xl font-bold text-white">{i18n.styleguide.elements.pills.title}</h3>
			<div class="flex flex-wrap items-center gap-3">
				<Pill text="React" image="/svg/react.svg" />
				<Pill text="Astro" image="/svg/astrojs.svg" />
				<Pill text="Tailwind" image="/svg/tailwindcss.svg" />
                <Pill text="TypeScript" image="/svg/typescript.svg" />
			</div>
            <p class="font-accent mt-6 text-sm text-neutral-400">
				{i18n.styleguide.elements.pills.description}
			</p>
		</div>

        <!-- Cards Showcase -->
		<div class="group rounded-2xl border border-neutral-800 bg-neutral-900/60 p-6 backdrop-blur-md transition-all hover:border-neutral-700 hover:bg-neutral-800/80 md:col-span-2">
			<h3 class="font-heading mb-6 text-xl font-bold text-white">{i18n.styleguide.elements.cards.title}</h3>
			<div class="grid grid-cols-1 gap-6 md:grid-cols-2">
				<!-- Light Card Example (Project style) -->
				<div class="w-full overflow-hidden rounded-lg border-2 border-neutral-100 bg-white text-black shadow-lg">
					<div class="h-32 w-full bg-neutral-200"></div>
					<div class="space-y-2 p-4">
						<h4 class="font-heading text-xl font-bold text-[#FFA84B]">Project Name</h4>
						<p class="font-accent text-xs text-neutral-600">{i18n.styleguide.elements.cards.light_desc}</p>
					</div>
				</div>
				<!-- Dark Card Example (Experience/Bento style) -->
				<div class="w-full overflow-hidden rounded-lg border border-neutral-800 bg-neutral-950 text-white shadow-xl">
					<div class="h-32 w-full bg-neutral-900"></div>
					<div class="space-y-2 p-4">
						<h4 class="font-heading text-xl font-bold text-white">Dark Card</h4>
						<p class="font-accent text-xs text-neutral-400">{i18n.styleguide.elements.cards.dark_desc}</p>
					</div>
				</div>
			</div>
		</div>
	</div>
</section>
