---
import Container from '@/components/common/Container.astro'
import Layout from '@/layouts/Layout.astro'
import { getI18N } from '@/i18n'
import { render } from 'astro:content'
import { getLangFromUrl, useTranslatedPath } from '@/i18n/utils'
import CopyLinkButton from '@/components/pages/CopyLinkButton.tsx'

const { post } = Astro.props;
const { Content } = await render(post);
const { currentLocale } = Astro
const i18n = getI18N({ currentLocale })
const lang = getLangFromUrl(Astro.url)
const translatePath = useTranslatedPath(lang)
---
<Layout title={`${post.data.title} | ${i18n.SEO.title}`}>
	<section class='relative min-h-screen pt-24 pb-24'>
		<Container>
            <article class="mx-auto max-w-5xl">
                <!-- Back Link -->
                <a href={translatePath('/blog')} class="inline-flex items-center gap-2 text-sm font-medium text-blue-500 hover:text-blue-600 transition-colors">
                    <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
                    </svg>
                    Volver al blog
                </a>

                <!-- Meta -->
                <div class="mt-8 flex flex-wrap items-center gap-2 font-accent text-xs font-semibold tracking-wider text-neutral-400 uppercase">
                    <span class="text-blue-500">{post.data.category || 'TUTORIALES'}</span>
                    <span>•</span>
                    <time>{post.data.pubDate.toLocaleDateString(lang, { year: 'numeric', month: 'long', day: 'numeric' })}</time>
                    <span>•</span>
                    <span class="flex items-center gap-1">
                        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                        </svg>
                        {(post.data.readTime || 3) === 1 ? '1 MINUTO' : `${post.data.readTime || 3} MINUTOS`} DE LECTURA
                    </span>
                </div>

                <!-- Title -->
                <h1 class="mt-6 font-display text-4xl font-bold leading-tight text-[#0f172a] md:text-5xl lg:text-6xl text-balance">
                    {post.data.title}
                </h1>

                <!-- Author & Share Row -->
                <div class="mt-8 flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between border-b border-neutral-200 pb-8">
                    <div class="flex items-center gap-4">
                        <div class="flex h-12 w-12 items-center justify-center rounded-full bg-blue-500 font-heading text-xl font-bold text-white">
                            {(post.data.author || 'F').charAt(0)}
                        </div>
                        <div>
                            <p class="font-heading font-bold text-neutral-900">{post.data.author || 'Fabián Hernández'}</p>
                            <p class="font-accent text-sm text-neutral-500">Desarrollador Web</p>
                        </div>
                    </div>
                    <CopyLinkButton client:idle />
                </div>

                <!-- Hero Image -->
                {post.data.image && (
                    <div class="mt-12 overflow-hidden rounded-[2rem] bg-neutral-100 shadow-sm border border-neutral-200">
                        <img src={post.data.image} alt={post.data.title} class="w-full aspect-[21/9] object-cover" />
                    </div>
                )}

                <!-- Content -->
                <div class="prose prose-neutral prose-lg mx-auto mt-16 max-w-3xl prose-headings:font-heading prose-headings:text-[#0f172a] prose-a:text-blue-500 hover:prose-a:text-blue-600 prose-img:rounded-2xl">
                    <Content />
                </div>
            </article>
		</Container>
	</section>
</Layout>
