---
import Container from '@/components/common/Container.astro'
import Colors from '@/components/styleGuide/colors.astro'
import Elements from '@/components/styleGuide/elements.astro'
import Icons from '@/components/styleGuide/icons.astro'
import Typo from '@/components/styleGuide/typo.astro'
import Layout from '@/layouts/Layout.astro'

import { getI18N } from '@/i18n'
const { currentLocale } = Astro
const i18n = getI18N({ currentLocale })
---

<Layout title={i18n.styleguide.title}>
	<section class='relative min-h-screen overflow-hidden py-16 lg:py-24'>
		<!-- Background Glows -->
		<div class='pointer-events-none absolute left-0 top-0 -z-10 h-full w-full opacity-20'>
			<div
				class='absolute top-[-10%] left-[10%] h-125 w-125 rounded-full bg-[#b16cea] blur-[120px] mix-blend-screen'
			>
			</div>
			<div
				class='absolute right-[10%] top-[30%] h-100 w-100 rounded-full bg-[#ff5e69] blur-[100px] mix-blend-screen'
			>
			</div>
		</div>

		<Container>
			<div class='flex flex-col items-center pb-16 pt-6'>
				<div
					class='mb-6 inline-flex items-center rounded-full border border-neutral-800 bg-neutral-900/50 px-3 py-1 text-sm font-medium text-neutral-300 backdrop-blur-md'
				>
					<span class='mr-2 h-2 w-2 rounded-full bg-linear-to-r from-[#ff5e69] to-[#ffa84b]'></span>
					{i18n.styleguide.badge}
				</div>
				<h1
					class='font-heading mb-4 bg-linear-to-r from-[#b16cea] from-10% via-[#ff5e69] via-30% to-[#ffa84b] to-90% bg-clip-text text-4xl font-bold tracking-tight text-transparent drop-shadow-sm md:text-6xl lg:text-7xl'
				>
					{i18n.styleguide.title}
				</h1>
				<p
					class='font-accent max-w-2xl text-center text-lg font-normal text-neutral-400 md:text-xl'
				>
					{i18n.styleguide.subtitle}
				</p>
			</div>

			<div class='space-y-24'>
				<Colors />
				<Typo />
				<Elements />
				<Icons />
			</div>
		</Container>
	</section>
</Layout>
