---
import Container from '@/components/common/Container.astro'
import SocialMediaLinks from '@/components/features/SocialMediaLinks.astro'
import { getI18N } from '@/i18n'
import { Image } from 'astro:assets'

const { currentLocale } = Astro
const i18n = getI18N({ currentLocale })
---

<Container>
	<section class='flex flex-col items-center justify-center pt-10 lg:flex-row lg:pt-16'>
		<div class='size-full flex-1 pr-4'>
			<h1
				class='font-heading bg-linear-to-r from-[#b16cea] from-10% via-[#ff5e69] via-30% to-[#ffa84b] to-90% bg-clip-text text-4xl font-bold tracking-tight text-transparent lg:h-37 lg:text-7xl'
			>
				{i18n.landing.title}
			</h1>
			<h2 class='font-heading text-3xl font-bold text-balance lg:text-5xl'>
				{i18n.landing.title_2}
			</h2>
			<p class='font-accent pt-4 text-base font-normal text-balance text-neutral-500 lg:text-xl'>
				{i18n.landing.subtitle}
			</p>
			<div>
				<SocialMediaLinks />
			</div>
		</div>
		<div class='relative -top-10 aspect-square h-auto w-80 select-none lg:w-147.5'>
			<div class='absolute inset-0 -z-10 scale-75 rounded-full bg-white/30 blur-2xl mix-blend-screen'></div>
			<Image
				src='/me.avif'
				alt='Fabian Herrera photo'
				width='600'
				height='600'
				loading='eager'
				fetchpriority='high'
				decoding='async'
				style='
			mask-image: linear-gradient(to bottom, white 50%, transparent 85%);
			aspect-ratio: 1/1;
		'
			/>
		</div>
	</section>
</Container>
